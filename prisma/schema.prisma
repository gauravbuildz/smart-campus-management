datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  name          String?
  email         String          @unique
  password      String
  role          String          @default("STUDENT") // STUDENT or ADMIN
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  notices       Notice[]
  issues        Issue[]
  lostFound     LostAndFound[]
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   // EVENT or NOTICE
  date        DateTime @default(now())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Issue {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   // HOSTEL, WIFI, CLASSROOM
  status      String   @default("PENDING") // PENDING or RESOLVED
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LostAndFound {
  id          String   @id @default(uuid())
  itemName    String
  description String
  type        String   // LOST or FOUND
  status      String   @default("REPORTED") // REPORTED or RESOLVED
  location    String
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
